FROM node:20-alpine

WORKDIR /app

COPY package*.json ./
COPY tsconfig.json ./

# Instala todas as deps incluindo devDependencies (ts-node-dev, etc.)
RUN npm install

# Migrations e scripts (src/ é montado como volume em runtime)
COPY migrations ./migrations
COPY scripts ./scripts

EXPOSE 8080

HEALTHCHECK --interval=10s --timeout=5s --retries=5 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:8080/health || exit 1
