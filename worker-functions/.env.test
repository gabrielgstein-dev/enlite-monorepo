# .env.test — variáveis para rodar API local + postgres local (sem Docker Compose completo)
# Uso: NODE_ENV=test dotenv -e .env.test -- npm start
NODE_ENV=test
PORT=8080
DATABASE_URL=postgresql://enlite_admin:enlite_password@localhost:5432/enlite_e2e
USE_MOCK_AUTH=true
USE_CERBOS=false
INTERNAL_TOKEN_SECRET=test-secret-e2e-only
API_URL=http://localhost:8080
# Talentum webhook — Google Service Account auth (Step 7)
# Em produção: URL pública da Cloud Function (ex: https://us-central1-PROJECT.cloudfunctions.net/FUNCTION_NAME)
# A Service Account do n8n deve ter o papel Cloud Functions Invoker no projeto GCP.
# Em testes (USE_MOCK_AUTH=true) essa variável é ignorada.
# TALENTUM_WEBHOOK_AUDIENCE=https://us-central1-<PROJECT_ID>.cloudfunctions.net/<FUNCTION_NAME>
