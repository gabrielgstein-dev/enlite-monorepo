# .env.prod — produção via Cloud SQL Proxy (porta 5435)
# Pré-requisitos: cloud-sql-proxy rodando na porta 5435
#   cloud-sql-proxy --port 5435 enlite-prd:southamerica-west1:enlite-ar-db
# A senha é preenchida automaticamente pelo script via Secret Manager
NODE_ENV=production
DB_HOST=localhost
DB_PORT=5432
DB_NAME=enlite_ar
DB_USER=enlite_app
# DB_PASSWORD é injetado via gcloud secrets — não commitar senha aqui
