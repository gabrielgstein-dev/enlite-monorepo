DATABASE_URL=postgresql://enlite_admin:enlite_password@localhost:5432/enlite_production
N8N_WEBHOOK_URL=http://localhost:5678/webhook/worker-events

# Google Cloud Identity Platform (HIPAA-compliant)
GCP_PROJECT_ID=enlite-prd
GCS_BUCKET_NAME=enlite-worker-documents
GCP_REGION=southamerica-east1
IDENTITY_PLATFORM_API_KEY=AIza...
FIREBASE_PROJECT_ID=enlite-health-prod
ALLOWED_ORIGIN=http://localhost:3000

# Cloud KMS Configuration (HIPAA Encryption)
KMS_KEYRING=enlite-keyring
KMS_KEY_NAME=worker-data-key

NODE_ENV=development
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
# URL configurada no Twilio Console para receber mensagens inbound do WhatsApp
TWILIO_INBOUND_WEBHOOK_URL=https://<domain>/api/webhooks/twilio/inbound

# Webhook Partner Auth
# Habilita endpoints de teste em /api/webhooks-test/ (automático em dev)
ENABLE_TEST_WEBHOOKS=true

# Google Calendar API (para resolução de datetimes de Meet links)
# Em produção (Cloud Run) não é necessário — usa a service account anexada ao serviço.
# Em desenvolvimento local, aponte para o JSON da service account baixado do GCP Console.
# GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/service-account.json
GOOGLE_CALENDAR_IMPERSONATE_EMAIL=enlite@enlite.health
USE_MOCK_GOOGLE_CALENDAR=false

# Internal Endpoints (Pub/Sub push, Cloud Tasks)
# INTERNAL_TOKEN_SECRET is shared with MultiAuthService — already defined above
CLOUD_TASKS_QUEUE_LOCATION=southamerica-west1
CLOUD_RUN_SERVICE_URL=http://localhost:8080

# Google Gemini API (vacancy text parsing via Gem)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-pro