{
  "name": "worker-functions",
  "version": "1.0.0",
  "description": "Enlite Health Platform - Worker Cloud Functions",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:e2e": "jest --config jest.config.e2e.js",
    "test:e2e:watch": "jest --config jest.config.e2e.js --watch",
    "test:e2e:coverage": "jest --config jest.config.e2e.js --coverage"
  },
  "keywords": [
    "enlite",
    "health",
    "hipaa",
    "cloud-functions",
    "worker"
  ],
  "author": "Enlite Health",
  "license": "PRIVATE",
  "dependencies": {
    "@google-cloud/functions-framework": "^3.3.0",
    "@google-cloud/kms": "^5.4.0",
    "axios": "^1.6.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "express": "^4.18.2",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.7.0",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
