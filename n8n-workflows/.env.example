# n8n Environment Variables for Production (Google Cloud Run + Cloud SQL)
# Documentação oficial: https://docs.n8n.io/hosting/installation/server-setups/google-cloud-run/

# Configurações de Host (NÃO ALTERAR para Cloud Run)
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=https

# URL do Webhook (ATUALIZAR após primeiro deploy do Cloud Run)
# Exemplo: https://enlite-n8n-xxx-uc.a.run.app/
WEBHOOK_URL=https://your-project-url.run.app/

# Banco de dados PostgreSQL via Cloud SQL
# IMPORTANTE: Para Cloud Run, usar Unix Socket ou Cloud SQL Proxy
DB_TYPE=postgresdb
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_HOST=/cloudsql/your-project:region:instance  # Unix socket path
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_USER=n8n_user
DB_POSTGRESDB_PASSWORD=your_db_password

# Configurações de Performance (Cloud Run)
N8N_CONCURRENCY_CONTROL_ENABLED=true
N8N_CONCURRENCY_CONTROL_MAX=10
N8N_PAYLOAD_SIZE_MAX=16  # MB - ajustar conforme necessidade

# Modo de execução (regular para Cloud Run)
EXECUTIONS_MODE=regular

# Logs
N8N_LOG_LEVEL=info

# Configurações opcionais para produção
# N8N_DEFAULT_BINARY_DATA_MODE=filesystem
# N8N_BINARY_DATA_STORAGE_PATH=/tmp/binary-data
