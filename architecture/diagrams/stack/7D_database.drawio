          <mxGeometry x="1020" y="630" width="280" height="20" as="geometry" />
        </mxCell>
        <mxCell id="audit_box" value="BigQuery (auditoria append-only)&#xa;&#xa;Toda ação de todos os serviços vai parar aqui. Não pode editar. Guardado por 6 anos.&#xa;Atende HIPAA 164.312(b) e LGPD Art.37." style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#F3E5F5;strokeColor=#6A1B9A;fontSize=13;fontColor=#4A148C;strokeWidth=3;fontStyle=1;" vertex="1" parent="1">
