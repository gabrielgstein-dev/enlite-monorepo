        <mxCell id="title" value="EnLite — 7E Segurança e Operação&#xa;Como protegemos, publicamos e monitoramos" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=22;fontStyle=1;fontColor=#202124;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1320" height="40" as="geometry" />
        </mxCell>
        <mxCell id="story" value="HISTÓRIA&#xa;&#xa;Três equipes invisíveis trabalham o tempo todo atrás da cortina:&#xa;• Segurança guarda as chaves e isola as áreas sensíveis.&#xa;• Observabilidade vigia tudo em tempo real e avisa se algo estranho acontecer.&#xa;• DevOps publica as atualizações com segurança, sem deixar ninguém colocar código não autorizado em produção." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF7C3;strokeColor=#F59E0B;fontSize=14;fontColor=#78350F;align=center;verticalAlign=middle;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="1320" height="140" as="geometry" />
        </mxCell>
        <mxCell id="sec_group" value="1. SEGURANÇA (chaves, perímetro, dados sensíveis)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;fontSize=14;fontStyle=1;verticalAlign=top;fontColor=#B71C1C;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="40" y="260" width="420" height="420" as="geometry" />
