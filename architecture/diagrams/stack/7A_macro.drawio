<mxfile host="app.diagrams.net" modified="2026-04-14T19:30:00.000Z" agent="Claude" version="24.0.0">
  <diagram id="macro" name="7A - Macro">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="EnLite — 7A Macro&#xa;Como a plataforma funciona em 4 blocos" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=22;fontStyle=1;fontColor=#202124;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1320" height="40" as="geometry" />
        </mxCell>
        <mxCell id="story" value="HISTÓRIA&#xa;&#xa;Em vez de pensar em dezenas de peças, pense em 4 blocos que conversam entre si.&#xa;O usuário abre o app (1) → fala com o cérebro da plataforma (2) → que consulta os dados (3).&#xa;Tudo roda dentro da Google Cloud (4), que é quem fornece os servidores e a segurança base." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF7C3;strokeColor=#F59E0B;fontSize=14;fontColor=#78350F;align=center;verticalAlign=middle;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="1320" height="120" as="geometry" />
        </mxCell>
        <mxCell id="block1" value="1. FRONTEND&#xa;&#xa;React (web)&#xa;React Native (mobile)&#xa;&#xa;O que o usuário vê e toca" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=16;fontColor=#0D47A1;strokeWidth=3;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="260" width="280" height="200" as="geometry" />
        </mxCell>
        <mxCell id="block2" value="2. BACKEND&#xa;&#xa;NestJS (TypeScript)&#xa;9 microsserviços&#xa;&#xa;O cérebro — regras de negócio" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C2185B;fontSize=16;fontColor=#880E4F;strokeWidth=3;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="260" width="280" height="200" as="geometry" />
        </mxCell>
        <mxCell id="block3" value="3. BANCO DE DADOS&#xa;&#xa;PostgreSQL (operacional)&#xa;Healthcare API (clínico)&#xa;Cloud Storage (documentos)&#xa;&#xa;Onde moram os dados" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;fontSize=16;fontColor=#B71C1C;strokeWidth=3;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="800" y="260" width="280" height="200" as="geometry" />
        </mxCell>
        <mxCell id="block4" value="4. GOOGLE CLOUD&#xa;&#xa;Servidores, rede, segurança,&#xa;monitoramento, backup.&#xa;&#xa;Região: São Paulo (Brasil)&#xa;&#xa;A fundação embaixo de tudo" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F0FE;strokeColor=#4285F4;fontSize=16;fontColor=#174EA6;strokeWidth=3;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1160" y="260" width="200" height="200" as="geometry" />
        </mxCell>
        <mxCell id="e1" style="endArrow=classic;html=1;rounded=0;strokeColor=#455A64;strokeWidth=3;fontSize=14;fontColor=#202124;" edge="1" parent="1" source="block1" target="block2">
          <mxGeometry relative="1" as="geometry" />
          <mxGeometry as="geometry">
            <Array as="points" />
