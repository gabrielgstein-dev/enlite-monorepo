<mxfile host="app.diagrams.net" modified="2026-04-14T19:30:00.000Z" agent="Claude" version="24.0.0">
  <diagram id="backend" name="7C - Backend">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="EnLite — 7C Backend&#xa;Com que a gente constrói a lógica" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=22;fontStyle=1;fontColor=#202124;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1320" height="40" as="geometry" />
        </mxCell>
        <mxCell id="story" value="HISTÓRIA&#xa;&#xa;O backend é o cérebro. Ele recebe pedidos do frontend, checa se a pessoa tem permissão, aplica regras de negócio e busca dados.&#xa;Em vez de um programa gigante, usamos 9 mini-programas (microsserviços) em NestJS — cada um com sua responsabilidade.&#xa;Os serviços comuns rodam em Cloud Run (barato e escala sozinho). Os que tocam dados clínicos rodam em GKE com isolamento reforçado." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF7C3;strokeColor=#F59E0B;fontSize=14;fontColor=#78350F;align=center;verticalAlign=middle;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="1320" height="140" as="geometry" />
        </mxCell>
        <mxCell id="gateway" value="API Gateway + Load Balancer&#xa;&#xa;Porta de entrada única&#xa;HTTPS + TLS 1.3&#xa;&#xa;(serviço GCP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#EF6C00;fontSize=14;fontColor=#E65100;strokeWidth=3;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="260" width="360" height="100" as="geometry" />
        </mxCell>
        <mxCell id="auth" value="Identity Platform&#xa;(Firebase Auth)&#xa;&#xa;Login + MFA obrigatório&#xa;&#xa;(serviço GCP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#EF6C00;fontSize=13;fontColor=#E65100;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="260" width="220" height="100" as="geometry" />
        </mxCell>
        <mxCell id="grupo_comum" value="Serviços comuns (Cloud Run — escala automática)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C2185B;fontSize=14;fontStyle=1;verticalAlign=top;fontColor=#880E4F;strokeWidth=3;" vertex="1" parent="1">
