        <mxCell id="stack_tech" value="Dentro de cada serviço:&#xa;&#xa;NestJS (framework) + TypeScript&#xa;Zod (validação de entrada)&#xa;Prisma ORM (acesso ao banco)&#xa;Cloud Tasks + Pub/Sub (filas e eventos)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#616161;fontSize=12;fontColor=#212121;" vertex="1" parent="1">
