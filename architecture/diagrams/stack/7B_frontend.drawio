        <mxCell id="title" value="EnLite — 7B Frontend&#xa;Com que a gente constrói as telas" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=22;fontStyle=1;fontColor=#202124;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1320" height="40" as="geometry" />
        </mxCell>
        <mxCell id="story" value="HISTÓRIA&#xa;&#xa;Existem dois tipos de tela: o painel que o coordenador usa no computador (web) e o app que o AT usa no celular.&#xa;Os dois são construídos com a mesma linguagem base (React + TypeScript), o que acelera a evolução.&#xa;O site é entregue pela rede global do Google (rápido em qualquer lugar) e protegido por um firewall inteligente." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF7C3;strokeColor=#F59E0B;fontSize=14;fontColor=#78350F;align=center;verticalAlign=middle;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="1320" height="130" as="geometry" />
        </mxCell>
        <mxCell id="user_web" value="Coordenador / Admin&#xa;no computador" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5F6368;fontSize=13;fontColor=#202124;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="280" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="user_mobile" value="AT no celular&#xa;(campo / paciente)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5F6368;fontSize=13;fontColor=#202124;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="520" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="web" value="Painel Web&#xa;&#xa;React 18 + Vite&#xa;TypeScript + Tailwind&#xa;&#xa;&quot;enlite-frontend&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=14;fontColor=#0D47A1;strokeWidth=3;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="260" width="240" height="140" as="geometry" />
        </mxCell>
