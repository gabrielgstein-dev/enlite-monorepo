{
  "permissions": {
    "allow": [
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Bash(cd worker-functions*)",
      "Bash(cd enlite-frontend*)",
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "WebFetch(domain:dev.to)",
      "Read(//Users/gabrielstein-dev/.claude/**)",
      "WebFetch(domain:github.com)",
      "mcp__local-rag__list_files"
    ],
    "defaultMode": "bypassPermissions",
    "additionalDirectories": [
      "/Users/gabrielstein-dev/projects/enlite/infra/.claude"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/validate-commit.sh",
            "if": "Bash(git commit *)"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/validate-migration.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-line-limit.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/rag-reingest.sh"
          }
        ]
      }
    ]
  }
}
